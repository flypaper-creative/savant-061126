@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@300;400;500;700&family=Space+Grotesk:wght@400;500;600;700&display=swap');
@import "tailwindcss";

@theme {
  --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
  --font-display: "Space Grotesk", sans-serif;
  --font-mono: "JetBrains Mono", ui-monospace, SFMono-Regular, monospace;
  
  /* Additional delicate shadows and micro animations for cinematic interfaces */
  --animate-scanline: scanline 8s linear infinite;
  --animate-radial-pulse: radialPulse 6s ease-in-out infinite;
  
  @keyframes scanline {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(100%); }
  }
  @keyframes radialPulse {
    0%, 100% { opacity: 0.15; }
    50% { opacity: 0.35; }
  }
}

/* Custom global scrollbar mechanics for pristine workspace look */
::-webkit-scrollbar {
  width: 4px;
  height: 4px;
}
::-webkit-scrollbar-track {
  background: rgba(0, 0, 0, 0.2);
}
::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.12);
  border-radius: 2px;
}
::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.25);
}

/* Clean up input focus outlines */
input:focus, textarea:focus, select:focus {
  outline: none;
}

/* Global visual defaults */
body {
  font-family: var(--font-mono);
  background-color: #000000;
  color: #d4d4d8;
  margin: 0;
  overflow: hidden;
}

/* SAVANT MASSIVE CONCEPT EVOLUTION LAYER */
.sv-upgraded-shell {
  isolation: isolate;
}

.sv-upgraded-shell::before {
  content: "";
  position: fixed;
  inset: 0;
  z-index: 8;
  pointer-events: none;
  background:
    radial-gradient(circle at 20% 20%, rgba(125,245,255,.12), transparent 32%),
    radial-gradient(circle at 82% 74%, rgba(255,182,92,.10), transparent 36%),
    linear-gradient(180deg, rgba(0,0,0,.08), rgba(0,0,0,.46));
  mix-blend-mode: screen;
}

.sv-evo-root {
  position: fixed;
  inset: max(10px, env(safe-area-inset-top, 0px)) max(10px, env(safe-area-inset-right, 0px)) max(10px, env(safe-area-inset-bottom, 0px)) max(10px, env(safe-area-inset-left, 0px));
  z-index: 30;
  pointer-events: none;
  display: grid;
  grid-template-columns: minmax(150px, 220px) minmax(280px, 1fr) minmax(190px, 300px);
  grid-template-rows: auto 1fr;
  gap: 10px;
  color: rgb(236,254,255);
  font-family: var(--font-mono);
}

.sv-evo-root * {
  box-sizing: border-box;
}

.sv-evo-root button {
  pointer-events: auto;
  cursor: pointer;
}

.sv-evo-topbar,
.sv-evo-pillar-rail,
.sv-evo-hero-card,
.sv-evo-system-card,
.sv-evo-right section {
  border: 1px solid rgba(125,245,255,.20);
  background:
    linear-gradient(135deg, rgba(3,8,12,.74), rgba(3,5,8,.56)),
    radial-gradient(circle at 20% 0%, rgba(125,245,255,.10), transparent 44%);
  backdrop-filter: blur(18px);
  box-shadow: 0 24px 80px rgba(0,0,0,.46);
}

.sv-evo-topbar {
  grid-column: 1 / -1;
  display: grid;
  grid-template-columns: 1fr auto auto;
  align-items: center;
  gap: 10px;
  border-radius: 20px;
  padding: 9px 10px;
  pointer-events: auto;
}

.sv-evo-brand,
.sv-evo-kicker,
.sv-evo-metrics,
.sv-evo-metrics div,
.sv-evo-actions,
.sv-evo-upgrade {
  display: flex;
  align-items: center;
  gap: 8px;
}

.sv-evo-brand b,
.sv-evo-hero-card h1 {
  letter-spacing: .18em;
  text-transform: uppercase;
}

.sv-evo-brand b {
  display: block;
  font-size: 11px;
}

.sv-evo-brand span,
.sv-evo-kicker span,
.sv-evo-system-card span,
.sv-evo-right li,
.sv-evo-log span {
  color: rgb(161,161,170);
  font-size: 9px;
  line-height: 1.55;
}

.sv-evo-metrics {
  gap: 6px;
}

.sv-evo-metrics div {
  border: 1px solid rgba(255,255,255,.10);
  border-radius: 999px;
  padding: 6px 8px;
  background: rgba(255,255,255,.04);
}

.sv-evo-metrics span {
  color: rgb(113,113,122);
  font-size: 7px;
  letter-spacing: .12em;
}

.sv-evo-metrics b {
  font-size: 9px;
}

.sv-evo-topbar button,
.sv-evo-actions button,
.sv-evo-pillar-rail button {
  border: 1px solid rgba(125,245,255,.20);
  background: rgba(125,245,255,.06);
  color: rgb(207,250,254);
  border-radius: 999px;
  padding: 8px 10px;
  font-size: 8px;
  letter-spacing: .14em;
  text-transform: uppercase;
}

.sv-evo-pillar-rail {
  grid-column: 1;
  grid-row: 2;
  border-radius: 22px;
  padding: 8px;
  display: grid;
  gap: 6px;
  align-content: start;
  pointer-events: auto;
}

.sv-evo-pillar-rail button {
  border-radius: 14px;
  text-align: left;
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 8px;
  align-items: center;
  background: rgba(255,255,255,.035);
}

.sv-evo-pillar-rail button.active {
  border-color: rgba(125,245,255,.68);
  background: rgba(125,245,255,.14);
  box-shadow: inset 0 0 34px rgba(125,245,255,.08);
}

.sv-evo-pillar-rail span {
  color: rgb(125,245,255);
  font-size: 8px;
}

.sv-evo-pillar-rail b {
  font-size: 9px;
}

.sv-evo-main {
  grid-column: 2;
  grid-row: 2;
  display: grid;
  gap: 10px;
  align-content: start;
}

.sv-evo-hero-card {
  border-radius: 28px;
  padding: clamp(16px, 3vw, 28px);
  min-height: 250px;
  pointer-events: auto;
}

.sv-evo-kicker {
  color: rgb(125,245,255);
  letter-spacing: .14em;
  text-transform: uppercase;
  margin-bottom: 12px;
}

.sv-evo-hero-card h1 {
  margin: 0;
  font-size: clamp(24px, 5vw, 58px);
  line-height: .92;
}

.sv-evo-hero-card p {
  max-width: 720px;
  color: rgb(212,212,216);
  font-size: clamp(12px, 1.4vw, 16px);
  line-height: 1.6;
}

.sv-evo-upgrade {
  margin-top: 14px;
  padding: 12px;
  border: 1px solid rgba(255,182,92,.22);
  border-radius: 18px;
  background: rgba(255,182,92,.06);
  color: rgb(255,237,213);
}

.sv-evo-upgrade span {
  font-size: 11px;
  line-height: 1.55;
}

.sv-evo-actions {
  flex-wrap: wrap;
  margin-top: 16px;
}

.sv-evo-actions button {
  display: flex;
  align-items: center;
  gap: 7px;
}

.sv-evo-system-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 8px;
}

.sv-evo-system-card {
  border-radius: 18px;
  padding: 12px;
  min-height: 92px;
  pointer-events: auto;
}

.sv-evo-system-card b {
  display: block;
  margin-top: 8px;
  font-size: 9px;
  letter-spacing: .12em;
  text-transform: uppercase;
}

.sv-evo-system-card span {
  display: block;
  margin-top: 4px;
}

.sv-evo-right {
  grid-column: 3;
  grid-row: 2;
  display: grid;
  gap: 10px;
  align-content: start;
}

.sv-evo-right section {
  border-radius: 22px;
  padding: 14px;
  pointer-events: auto;
}

.sv-evo-right ol {
  padding-left: 18px;
  margin: 0;
}

.sv-evo-log {
  display: grid;
  gap: 6px;
}

.sv-evo-log span {
  border-top: 1px solid rgba(255,255,255,.07);
  padding-top: 6px;
}

.sv-evo-root.is-compact {
  inset: max(8px, env(safe-area-inset-top, 0px)) max(8px, env(safe-area-inset-right, 0px)) auto max(8px, env(safe-area-inset-left, 0px));
  display: block;
}

.sv-evo-root.is-compact .sv-evo-topbar {
  display: flex;
  justify-content: space-between;
}

.sv-boot-overlay {
  opacity: .92;
}

@media (max-width: 980px) {
  .sv-evo-root {
    grid-template-columns: 1fr;
    grid-template-rows: auto auto 1fr;
  }

  .sv-evo-pillar-rail {
    grid-column: 1;
    grid-row: 2;
    grid-template-columns: repeat(7, minmax(92px, 1fr));
    overflow-x: auto;
  }

  .sv-evo-main {
    grid-column: 1;
    grid-row: 3;
  }

  .sv-evo-right {
    display: none;
  }

  .sv-evo-system-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .sv-evo-hero-card {
    min-height: 0;
  }
}

@media (max-width: 680px), (pointer: coarse) {
  .sv-evo-root {
    inset: 6px;
    gap: 6px;
  }

  .sv-evo-topbar {
    grid-template-columns: 1fr auto;
  }

  .sv-evo-metrics {
    display: none;
  }

  .sv-evo-brand b {
    font-size: 9px;
  }

  .sv-evo-brand span {
    font-size: 7px;
  }

  .sv-evo-pillar-rail {
    display: none;
  }

  .sv-evo-main {
    grid-row: 2;
  }

  .sv-evo-hero-card {
    border-radius: 20px;
    padding: 14px;
    max-height: 42dvh;
    overflow: auto;
  }

  .sv-evo-hero-card h1 {
    font-size: 24px;
  }

  .sv-evo-hero-card p,
  .sv-evo-upgrade span {
    font-size: 10px;
  }

  .sv-evo-system-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    max-height: 28dvh;
    overflow: auto;
  }

  .sv-evo-system-card {
    min-height: 76px;
    padding: 9px;
  }

  .sv-evo-actions button {
    padding: 7px 9px;
  }
}

/* SAVANT TOTAL OPTIMIZATION CURRENT BASELINE */
html,
body,
#root {
  width: 100%;
  height: 100%;
  min-height: 100dvh;
  margin: 0;
  overflow: hidden;
  background: #020305;
  text-rendering: geometricPrecision;
  -webkit-font-smoothing: antialiased;
}

.sv-optimized-space-scene {
  position: fixed;
  inset: 0;
  z-index: 1;
  width: 100vw;
  height: 100dvh;
  overflow: hidden;
  background:
    radial-gradient(circle at 50% 50%, rgba(125,245,255,.055), transparent 45%),
    #020305;
  contain: strict;
}

.sv-optimized-space-scene canvas {
  display: block;
  width: 100% !important;
  height: 100% !important;
  touch-action: none;
}

.sv-optics-root {
  position: fixed;
  inset: 0;
  z-index: 6;
  pointer-events: none;
  overflow: hidden;
  contain: strict;
}

.sv-optics-vignette,
.sv-optics-depth,
.sv-optics-glass {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.sv-optics-vignette {
  background:
    radial-gradient(circle at 50% 42%, transparent 52%, rgba(0,0,0,.64) 100%),
    linear-gradient(180deg, rgba(255,255,255,.025), transparent 18%, rgba(0,0,0,.32));
}

.sv-optics-depth {
  background:
    radial-gradient(circle at 20% 18%, rgba(125,245,255,.08), transparent 34%),
    radial-gradient(circle at 84% 76%, rgba(255,182,92,.07), transparent 38%);
  mix-blend-mode: screen;
  opacity: .78;
}

.sv-optics-glass {
  background:
    linear-gradient(110deg, rgba(255,255,255,.052), transparent 18%, transparent 72%, rgba(255,255,255,.026)),
    radial-gradient(circle at 50% 0%, rgba(255,255,255,.035), transparent 42%);
  opacity: .70;
}

.sv-optics-root::before,
.sv-optics-root::after,
#savant-crt-visual-overlay,
.animate-scanline {
  background-image: none !important;
  animation: none !important;
}

.sv-upgraded-shell::before {
  background:
    radial-gradient(circle at 22% 22%, rgba(125,245,255,.08), transparent 32%),
    radial-gradient(circle at 82% 74%, rgba(255,182,92,.07), transparent 36%),
    linear-gradient(180deg, rgba(0,0,0,.04), rgba(0,0,0,.38)) !important;
}

.sv-evo-root {
  z-index: 32 !important;
  will-change: auto;
}

.sv-evo-topbar,
.sv-evo-pillar-rail,
.sv-evo-hero-card,
.sv-evo-system-card,
.sv-evo-right section {
  backdrop-filter: blur(14px) saturate(1.12) !important;
}

.sv-evo-system-grid {
  content-visibility: auto;
  contain-intrinsic-size: 320px;
}

#boot-terminal-dashboard,
#arrived-studio-screen {
  z-index: 40;
}

#boot-terminal-dashboard * ,
#arrived-studio-screen * {
  scrollbar-width: thin;
}

@media (max-width: 760px), (pointer: coarse) {
  .sv-evo-root {
    inset: 6px !important;
  }

  .sv-evo-hero-card {
    max-height: 38dvh !important;
  }

  .sv-evo-system-grid {
    max-height: 24dvh !important;
  }

  #boot-terminal-dashboard {
    padding: 6px !important;
  }

  #boot-terminal-dashboard > div {
    max-height: calc(100dvh - 12px);
    overflow: auto;
  }

  #arrived-studio-screen {
    padding: 6px !important;
  }

  #arrived-studio-screen > div {
    max-height: calc(100dvh - 12px);
    overflow: auto;
  }
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: .001ms !important;
    animation-iteration-count: 1 !important;
    scroll-behavior: auto !important;
    transition-duration: .001ms !important;
  }
}
