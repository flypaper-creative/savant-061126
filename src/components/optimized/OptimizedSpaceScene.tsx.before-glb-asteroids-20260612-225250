import React, { memo, useEffect, useRef } from 'react';
import * as THREE from 'three';
import { useAppState } from '../../contexts/AppStateContext';

type Rock = {
  x: number;
  y: number;
  z: number;
  vx: number;
  vy: number;
  vz: number;
  rx: number;
  ry: number;
  rz: number;
  sx: number;
  sy: number;
  sz: number;
  spinX: number;
  spinY: number;
  spinZ: number;
  scale: number;
};

const rand = (a: number, b: number) => a + Math.random() * (b - a);

const themeToColor = (theme: string) => {
  switch (theme) {
    case 'CHROME_BLOOD': return { rock: 0x7d7f86, accent: 0xef4444, fog: 0x050306 };
    case 'GOLD_GUNMETAL': return { rock: 0xb98942, accent: 0xf59e0b, fog: 0x070503 };
    case 'OBSIDIAN_MOTTLED': return { rock: 0x151820, accent: 0x00f2ff, fog: 0x020408 };
    case 'CARBON_VIOLET': return { rock: 0x282231, accent: 0xd946ef, fog: 0x040208 };
    case 'OPAL_STARDUST': return { rock: 0x9fb5c5, accent: 0xfb923c, fog: 0x060504 };
    case 'IRON_GREEN': return { rock: 0x52615a, accent: 0x10b981, fog: 0x020605 };
    case 'QUICKSILVER_COPPER': return { rock: 0x87847d, accent: 0xf97316, fog: 0x060403 };
    default: return { rock: 0x4a4640, accent: 0x00f2ff, fog: 0x020305 };
  }
};

const createAsteroidGeometry = () => {
  const geo = new THREE.DodecahedronGeometry(1, 5);
  const pos = geo.getAttribute('position');

  for (let i = 0; i < pos.count; i += 1) {
    const x = pos.getX(i);
    const y = pos.getY(i);
    const z = pos.getZ(i);

    const n = new THREE.Vector3(x, y, z).normalize();
    const ridge =
      Math.sin(n.x * 9.7 + n.y * 3.1) * 0.20 +
      Math.sin(n.z * 17.1 + n.x * 5.3) * 0.16 +
      Math.sin(n.y * 31.0 + n.z * 11.0) * 0.07;

    const crater = -Math.pow(Math.abs(Math.sin(n.x * 19.0 + n.y * 23.0 + n.z * 29.0)), 3.0) * 0.12;
    const s = Math.max(0.48, 1 + ridge + crater);

    pos.setXYZ(i, x * s, y * s, z * s);
  }

  geo.computeVertexNormals();
  geo.computeBoundingSphere();

  return geo;
};

export const OptimizedSpaceScene: React.FC = memo(() => {
  const mountRef = useRef<HTMLDivElement | null>(null);
  const { asteroidTheme } = useAppState();

  useEffect(() => {
    const mount = mountRef.current;
    if (!mount) return;

    const reducedMotion = window.matchMedia?.('(prefers-reduced-motion: reduce)').matches;
    const coarse = window.matchMedia?.('(pointer: coarse)').matches;
    const lowMemory = (navigator as any).deviceMemory && (navigator as any).deviceMemory <= 4;

    const renderer = new THREE.WebGLRenderer({
      antialias: !coarse,
      alpha: false,
      powerPreference: 'high-performance'
    });

    const pixelRatio = Math.min(window.devicePixelRatio || 1, coarse || lowMemory ? 1.15 : 1.5);
    renderer.setPixelRatio(pixelRatio);
    renderer.setSize(mount.clientWidth || window.innerWidth, mount.clientHeight || window.innerHeight);
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.06;

    mount.replaceChildren(renderer.domElement);

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(48, 1, 0.1, 7000);
    camera.position.set(0, 80, 620);

    const colors = themeToColor(asteroidTheme);
    scene.background = new THREE.Color(colors.fog);
    scene.fog = new THREE.FogExp2(colors.fog, 0.00092);

    const ambient = new THREE.AmbientLight(0x6f7f91, 0.42);
    const key = new THREE.DirectionalLight(0xe7fbff, 3.2);
    key.position.set(420, 620, 360);

    const rim = new THREE.DirectionalLight(colors.accent, 1.45);
    rim.position.set(-520, 180, -420);

    const warm = new THREE.PointLight(0xffb65c, 0.62, 1200);
    warm.position.set(260, -120, -320);

    scene.add(ambient, key, rim, warm);

    const starCount = coarse || lowMemory ? 1700 : 4200;
    const starPositions = new Float32Array(starCount * 3);
    const starColors = new Float32Array(starCount * 3);
    const starBase = new THREE.Color(0xdceeff);
    const starAccent = new THREE.Color(colors.accent);

    for (let i = 0; i < starCount; i += 1) {
      starPositions[i * 3] = rand(-2600, 2600);
      starPositions[i * 3 + 1] = rand(-1300, 1300);
      starPositions[i * 3 + 2] = rand(-4200, -600);

      const c = Math.random() < 0.12 ? starAccent : starBase;
      starColors[i * 3] = c.r;
      starColors[i * 3 + 1] = c.g;
      starColors[i * 3 + 2] = c.b;
    }

    const starGeo = new THREE.BufferGeometry();
    starGeo.setAttribute('position', new THREE.BufferAttribute(starPositions, 3));
    starGeo.setAttribute('color', new THREE.BufferAttribute(starColors, 3));

    const starMat = new THREE.PointsMaterial({
      size: coarse ? 1.35 : 1.05,
      vertexColors: true,
      transparent: true,
      opacity: 0.74,
      depthWrite: false,
      blending: THREE.AdditiveBlending
    });

    const stars = new THREE.Points(starGeo, starMat);
    scene.add(stars);

    const asteroidGeo = createAsteroidGeometry();
    const rockMaterial = new THREE.MeshStandardMaterial({
      color: colors.rock,
      emissive: new THREE.Color(colors.fog),
      roughness: 0.88,
      metalness: 0.10,
      envMapIntensity: 0.75
    });

    const count = coarse || lowMemory ? 150 : 420;
    const instanced = new THREE.InstancedMesh(asteroidGeo, rockMaterial, count);
    instanced.instanceMatrix.setUsage(THREE.DynamicDrawUsage);
    instanced.frustumCulled = false;

    const dummy = new THREE.Object3D();
    const rocks: Rock[] = [];

    for (let i = 0; i < count; i += 1) {
      const scale = rand(2.2, 22) * (Math.random() > 0.92 ? 2.1 : 1);
      rocks.push({
        x: rand(-980, 980),
        y: rand(-420, 320),
        z: rand(-1100, 260),
        vx: rand(0.18, 1.35),
        vy: rand(0.06, 0.42),
        vz: rand(-0.04, 0.04),
        rx: rand(0, Math.PI),
        ry: rand(0, Math.PI),
        rz: rand(0, Math.PI),
        sx: rand(0.45, 2.9),
        sy: rand(0.38, 2.0),
        sz: rand(0.42, 2.7),
        spinX: rand(-0.009, 0.009),
        spinY: rand(-0.012, 0.012),
        spinZ: rand(-0.009, 0.009),
        scale
      });
    }

    scene.add(instanced);

    const hero = new THREE.Mesh(asteroidGeo, rockMaterial);
    hero.position.set(-120, -20, -20);
    hero.scale.set(90, 62, 112);
    scene.add(hero);

    const nebulaMatA = new THREE.MeshBasicMaterial({
      color: colors.accent,
      transparent: true,
      opacity: 0.035,
      depthWrite: false,
      blending: THREE.AdditiveBlending,
      side: THREE.DoubleSide
    });

    const nebulaA = new THREE.Mesh(new THREE.PlaneGeometry(2600, 900), nebulaMatA);
    nebulaA.position.set(-760, 260, -1500);
    nebulaA.rotation.set(0.18, -0.46, 0.12);
    scene.add(nebulaA);

    let raf = 0;
    let last = performance.now();

    const resize = () => {
      const w = mount.clientWidth || window.innerWidth;
      const h = mount.clientHeight || window.innerHeight;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    };

    resize();
    window.addEventListener('resize', resize, { passive: true });

    const animate = (now: number) => {
      raf = requestAnimationFrame(animate);

      const dt = Math.min(0.033, (now - last) / 1000);
      last = now;

      const t = now * 0.001;
      const motionScale = reducedMotion ? 0.25 : 1;

      stars.position.x = ((camera.position.x * 0.018) - t * 30 * motionScale) % 1600;
      stars.position.y = camera.position.y * 0.006;

      hero.rotation.x += dt * 0.11 * motionScale;
      hero.rotation.y += dt * 0.16 * motionScale;
      hero.rotation.z += dt * 0.04 * motionScale;
      hero.position.x = -120 + Math.sin(t * 0.22) * 18;

      for (let i = 0; i < rocks.length; i += 1) {
        const rock = rocks[i];

        rock.x += rock.vx * 60 * dt * motionScale;
        rock.y += rock.vy * 60 * dt * motionScale;
        rock.z += rock.vz * 60 * dt * motionScale;

        rock.rx += rock.spinX * 60 * dt * motionScale;
        rock.ry += rock.spinY * 60 * dt * motionScale;
        rock.rz += rock.spinZ * 60 * dt * motionScale;

        if (rock.x > 1080 || rock.y > 440 || rock.z < -1200 || rock.z > 380) {
          rock.x = -1080 - Math.random() * 220;
          rock.y = -430 + Math.random() * 160;
          rock.z = -1100 + Math.random() * 1400;
        }

        dummy.position.set(rock.x, rock.y, rock.z);
        dummy.rotation.set(rock.rx, rock.ry, rock.rz);
        dummy.scale.set(
          rock.scale * rock.sx,
          rock.scale * rock.sy,
          rock.scale * rock.sz
        );
        dummy.updateMatrix();
        instanced.setMatrixAt(i, dummy.matrix);
      }

      instanced.instanceMatrix.needsUpdate = true;

      camera.position.x = Math.sin(t * 0.12) * 28;
      camera.position.y = 80 + Math.sin(t * 0.10) * 12;
      camera.lookAt(0, 0, -120);

      renderer.render(scene, camera);
    };

    raf = requestAnimationFrame(animate);

    return () => {
      cancelAnimationFrame(raf);
      window.removeEventListener('resize', resize);

      mount.replaceChildren();

      starGeo.dispose();
      starMat.dispose();
      asteroidGeo.dispose();
      rockMaterial.dispose();
      nebulaA.geometry.dispose();
      nebulaMatA.dispose();
      renderer.dispose();
    };
  }, [asteroidTheme]);

  return <div ref={mountRef} className="sv-optimized-space-scene" aria-hidden="true" />;
});

OptimizedSpaceScene.displayName = 'OptimizedSpaceScene';
