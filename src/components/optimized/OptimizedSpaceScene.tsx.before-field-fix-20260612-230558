import React, { memo, useEffect, useRef } from 'react';
import * as THREE from 'three';
import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';
import { useAppState } from '../../contexts/AppStateContext';

type Rock = {
  x: number; y: number; z: number;
  vx: number; vy: number; vz: number;
  rx: number; ry: number; rz: number;
  sx: number; sy: number; sz: number;
  spinX: number; spinY: number; spinZ: number;
  scale: number;
};

const rand = (a: number, b: number) => a + Math.random() * (b - a);

const themeToColor = (theme: string) => {
  switch (theme) {
    case 'CHROME_BLOOD': return { accent: 0xef4444, fog: 0x050306 };
    case 'GOLD_GUNMETAL': return { accent: 0xf59e0b, fog: 0x070503 };
    case 'OBSIDIAN_MOTTLED': return { accent: 0x00f2ff, fog: 0x020408 };
    case 'CARBON_VIOLET': return { accent: 0xd946ef, fog: 0x040208 };
    case 'OPAL_STARDUST': return { accent: 0xfb923c, fog: 0x060504 };
    case 'IRON_GREEN': return { accent: 0x10b981, fog: 0x020605 };
    case 'QUICKSILVER_COPPER': return { accent: 0xf97316, fog: 0x060403 };
    default: return { accent: 0x00f2ff, fog: 0x020305 };
  }
};

const extractFirstMesh = (root: THREE.Object3D): THREE.Mesh => {
  let found: THREE.Mesh | null = null;
  root.traverse((obj) => {
    if (!found && (obj as THREE.Mesh).isMesh) found = obj as THREE.Mesh;
  });
  if (!found) throw new Error('No mesh found in /assets/ast/ast.glb');
  return found;
};

export const OptimizedSpaceScene: React.FC = memo(() => {
  const mountRef = useRef<HTMLDivElement | null>(null);
  const { asteroidTheme } = useAppState();

  useEffect(() => {
    const mount = mountRef.current;
    if (!mount) return;

    let disposed = false;
    let raf = 0;

    const coarse = window.matchMedia?.('(pointer: coarse)').matches;
    const lowMemory = (navigator as any).deviceMemory && (navigator as any).deviceMemory <= 4;
    const reducedMotion = window.matchMedia?.('(prefers-reduced-motion: reduce)').matches;

    const renderer = new THREE.WebGLRenderer({
      antialias: !coarse,
      alpha: false,
      powerPreference: 'high-performance'
    });

    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, coarse || lowMemory ? 1.15 : 1.5));
    renderer.setSize(mount.clientWidth || window.innerWidth, mount.clientHeight || window.innerHeight);
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.1;

    mount.replaceChildren(renderer.domElement);

    const scene = new THREE.Scene();
    const colors = themeToColor(asteroidTheme);
    scene.background = new THREE.Color(colors.fog);
    scene.fog = new THREE.FogExp2(colors.fog, 0.00082);

    const camera = new THREE.PerspectiveCamera(44, 1, 0.1, 8000);
    camera.position.set(0, 90, 660);

    scene.add(new THREE.AmbientLight(0x6f8192, 0.38));

    const key = new THREE.DirectionalLight(0xe7fbff, 3.85);
    key.position.set(520, 720, 420);
    scene.add(key);

    const rim = new THREE.DirectionalLight(colors.accent, 1.75);
    rim.position.set(-620, 240, -520);
    scene.add(rim);

    const warm = new THREE.PointLight(0xffb65c, 0.72, 1400);
    warm.position.set(360, -160, -360);
    scene.add(warm);

    const starCount = coarse || lowMemory ? 1800 : 5200;
    const starPositions = new Float32Array(starCount * 3);
    const starColors = new Float32Array(starCount * 3);
    const baseStar = new THREE.Color(0xdceeff);
    const accentStar = new THREE.Color(colors.accent);

    for (let i = 0; i < starCount; i++) {
      starPositions[i * 3] = rand(-3000, 3000);
      starPositions[i * 3 + 1] = rand(-1500, 1500);
      starPositions[i * 3 + 2] = rand(-5000, -700);

      const c = Math.random() < 0.13 ? accentStar : baseStar;
      starColors[i * 3] = c.r;
      starColors[i * 3 + 1] = c.g;
      starColors[i * 3 + 2] = c.b;
    }

    const starGeo = new THREE.BufferGeometry();
    starGeo.setAttribute('position', new THREE.BufferAttribute(starPositions, 3));
    starGeo.setAttribute('color', new THREE.BufferAttribute(starColors, 3));

    const starMat = new THREE.PointsMaterial({
      size: coarse ? 1.35 : 1.05,
      vertexColors: true,
      transparent: true,
      opacity: 0.72,
      depthWrite: false,
      blending: THREE.AdditiveBlending
    });

    const stars = new THREE.Points(starGeo, starMat);
    scene.add(stars);

    const nebulaMat = new THREE.MeshBasicMaterial({
      color: colors.accent,
      transparent: true,
      opacity: 0.034,
      depthWrite: false,
      blending: THREE.AdditiveBlending,
      side: THREE.DoubleSide
    });

    const nebula = new THREE.Mesh(new THREE.PlaneGeometry(3000, 980), nebulaMat);
    nebula.position.set(-840, 280, -1700);
    nebula.rotation.set(0.18, -0.46, 0.12);
    scene.add(nebula);

    const loader = new GLTFLoader();

    loader.load(
      '/assets/ast/ast.glb',
      (gltf) => {
        if (disposed) return;

        const sourceMesh = extractFirstMesh(gltf.scene);
        const geometry = sourceMesh.geometry.clone();
        geometry.computeVertexNormals();
        geometry.computeBoundingSphere();
        geometry.center();

        const materialSource = sourceMesh.material;
        const material = Array.isArray(materialSource)
          ? materialSource[0].clone()
          : materialSource.clone();

        if (material instanceof THREE.MeshStandardMaterial) {
          material.roughness = Math.max(material.roughness ?? 0.8, 0.82);
          material.metalness = Math.min(material.metalness ?? 0.05, 0.18);
          material.envMapIntensity = 1.15;
        }

        const hero = new THREE.Mesh(geometry, material);
        hero.position.set(-135, -18, -28);
        hero.scale.setScalar(95);
        scene.add(hero);

        const count = coarse || lowMemory ? 150 : 440;
        const instanced = new THREE.InstancedMesh(geometry, material, count);
        instanced.instanceMatrix.setUsage(THREE.DynamicDrawUsage);
        instanced.frustumCulled = false;
        scene.add(instanced);

        const dummy = new THREE.Object3D();
        const rocks: Rock[] = [];

        for (let i = 0; i < count; i++) {
          const scale = rand(3.2, 23) * (Math.random() > 0.92 ? 2.2 : 1);
          rocks.push({
            x: rand(-1080, 1080),
            y: rand(-430, 330),
            z: rand(-1220, 280),
            vx: rand(0.18, 1.35),
            vy: rand(0.06, 0.42),
            vz: rand(-0.04, 0.04),
            rx: rand(0, Math.PI),
            ry: rand(0, Math.PI),
            rz: rand(0, Math.PI),
            sx: rand(0.65, 1.85),
            sy: rand(0.62, 1.45),
            sz: rand(0.70, 1.75),
            spinX: rand(-0.009, 0.009),
            spinY: rand(-0.012, 0.012),
            spinZ: rand(-0.009, 0.009),
            scale
          });
        }

        let last = performance.now();

        const animate = (now: number) => {
          raf = requestAnimationFrame(animate);
          const dt = Math.min(0.033, (now - last) / 1000);
          last = now;

          const t = now * 0.001;
          const motion = reducedMotion ? 0.25 : 1;

          stars.position.x = ((camera.position.x * 0.018) - t * 30 * motion) % 1800;
          stars.position.y = camera.position.y * 0.006;

          hero.rotation.x += dt * 0.07 * motion;
          hero.rotation.y += dt * 0.10 * motion;
          hero.rotation.z += dt * 0.025 * motion;
          hero.position.x = -135 + Math.sin(t * 0.18) * 16;

          for (let i = 0; i < rocks.length; i++) {
            const rock = rocks[i];

            rock.x += rock.vx * 60 * dt * motion;
            rock.y += rock.vy * 60 * dt * motion;
            rock.z += rock.vz * 60 * dt * motion;

            rock.rx += rock.spinX * 60 * dt * motion;
            rock.ry += rock.spinY * 60 * dt * motion;
            rock.rz += rock.spinZ * 60 * dt * motion;

            if (rock.x > 1180 || rock.y > 450 || rock.z < -1280 || rock.z > 380) {
              rock.x = -1180 - Math.random() * 240;
              rock.y = -430 + Math.random() * 170;
              rock.z = -1220 + Math.random() * 1500;
            }

            dummy.position.set(rock.x, rock.y, rock.z);
            dummy.rotation.set(rock.rx, rock.ry, rock.rz);
            dummy.scale.set(rock.scale * rock.sx, rock.scale * rock.sy, rock.scale * rock.sz);
            dummy.updateMatrix();
            instanced.setMatrixAt(i, dummy.matrix);
          }

          instanced.instanceMatrix.needsUpdate = true;

          camera.position.x = Math.sin(t * 0.10) * 26;
          camera.position.y = 90 + Math.sin(t * 0.09) * 10;
          camera.lookAt(0, 0, -140);

          renderer.render(scene, camera);
        };

        raf = requestAnimationFrame(animate);
      },
      undefined,
      (error) => {
        console.error('[SAVANT] failed to load asteroid GLB', error);
      }
    );

    const resize = () => {
      const w = mount.clientWidth || window.innerWidth;
      const h = mount.clientHeight || window.innerHeight;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    };

    resize();
    window.addEventListener('resize', resize, { passive: true });

    return () => {
      disposed = true;
      cancelAnimationFrame(raf);
      window.removeEventListener('resize', resize);
      mount.replaceChildren();

      starGeo.dispose();
      starMat.dispose();
      nebula.geometry.dispose();
      nebulaMat.dispose();
      renderer.dispose();
    };
  }, [asteroidTheme]);

  return <div ref={mountRef} className="sv-optimized-space-scene" aria-hidden="true" />;
});

OptimizedSpaceScene.displayName = 'OptimizedSpaceScene';
